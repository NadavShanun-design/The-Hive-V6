{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "geodo",
    "version": "16.0.0",
    "identifier": "com.geodo.main",
    "build": {
        "frontendDist": "../out",
        "devUrl": "http://localhost:3118",
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build"
    },
    "app": {
        "windows": [
            {
                "label": "login",
                "title": "Sign in to Geodo",
                "url": "/login",
                "width": 500,
                "height": 650,
                "resizable": false,
                "center": true,
                "fullscreen": false,
                "theme": "Light",
                "decorations": true,
                "visible": true
            },
            {
                "label": "main",
                "title": "Geodo",
                "url": "/",
                "width": 1100,
                "height": 700,
                "resizable": true,
                "center": true,
                "fullscreen": false,
                "theme": "Light",
                "decorations": true,
                "visible": false
            }
        ],
        "macOSPrivateApi": true,
        "security": {
            "csp": {
                "default-src": "'self'",
                "style-src": "'self' 'unsafe-inline'",
                "img-src": "'self' asset: https://asset.localhost data: https://*.clerk.accounts.dev https://*.clerk.com",
                "connect-src": "'self' http://localhost:11434 http://localhost:5167 http://localhost:8178 https://api.ollama.ai https://api.openai.com https://mail.google.com https://*.clerk.accounts.dev https://*.clerk.com https://clerk.desired-tuna-97.lcl.dev wss://*.clerk.accounts.dev wss://*.clerk.com",
                "script-src": "'self' 'unsafe-inline' 'unsafe-eval' https://*.clerk.accounts.dev https://*.clerk.com",
                "frame-src": "'self' https://*.clerk.accounts.dev https://*.clerk.com"
            },
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "$APPDATA/**"
                ]
            },
            "capabilities": [
                {
                    "identifier": "main",
                    "description": "Main window capability with file system and media access",
                    "windows": [
                        "main",
                        "login"
                    ],
                    "permissions": [
                        "fs:default",
                        "fs:allow-read-file",
                        "fs:read-all",
                        "fs:write-all",
                        "fs:allow-app-read",
                        "fs:allow-app-write",
                        "fs:allow-download-write",
                        "fs:allow-download-read",
                        "fs:scope-download",
                        "core:path:default",
                        "core:event:default",
                        "core:window:default",
                        "core:app:default",
                        "core:resources:default",
                        "core:menu:default",
                        "core:tray:default",
                        "core:window:allow-set-title",
                        "store:default",
                        "notification:default",
                        "notification:allow-is-permission-granted",
                        "updater:default",
                        "process:default",
                        "clerk:default",
                        {
                            "identifier": "http:default",
                            "allow": [
                                {"url": "https://*"}
                            ]
                        },
                        {
                            "identifier": "fs:scope",
                            "allow": [
                                {
                                    "path": "$APPDATA/*"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "deb",
            "appimage",
            "msi",
            "nsis",
            "app",
            "dmg"
        ],
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/icon.png",
            "icons/app_icon.icns",
            "icons/app_icon.ico"
        ],
        "resources": [
            "templates/*.json"
        ],
        "externalBin": [
            "binaries/llama-helper"
        ],
        "macOS": {
            "entitlements": "entitlements.plist",
            "signingIdentity": "9E42027A7959735B365D024CD1F33261B0E5AFDC",
            "hardenedRuntime": true,
            "providerShortName": "T5KKCBUDB7"
        },
        "windows": {
            "signCommand": "powershell -ExecutionPolicy Bypass -File scripts/sign-windows.ps1 -FilePath %1"
        }
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDQTYzMUQ3ODc5N0M4MkEKUldRcXlKZUgxekdtN09DRkVWSHNpZlJseEVOUmpNd1dDSTNaLzZ3MXJGTnY3WW1pdnlOYjBpbkIK",
            "endpoints": [
                "https://github.com/Zackriya-Solutions/meeting-minutes/releases/latest/download/latest.json"
            ]
        }
    }
}