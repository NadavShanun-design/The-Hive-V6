# THE HIVE - Environment Variables Configuration

# Server Configuration
PORT=3002
NODE_ENV=development

# Anthropic Claude API (for Claude Code CLI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenClaw Gateway Configuration
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your_openclaw_token_here

# Project Workspaces (auto-created if not exist)
PROJECT_1_DIR=./projects/project-1
PROJECT_2_DIR=./projects/project-2
PROJECT_3_DIR=./projects/project-3

# WebSocket Configuration
WEBSOCKET_PORT=3002

# Cloudflare Tunnel (for production deployment)
# After setting up cloudflared, get your tunnel URL:
# CLOUDFLARE_TUNNEL_URL=https://your-tunnel-subdomain.trycloudflare.com

# Frontend Configuration (if hosting on Cloudflare Pages)
# NEXT_PUBLIC_WS_URL=wss://your-tunnel-subdomain.trycloudflare.com
